rules_version = '2';

// ─────────────────────────────────────────────────────────────────────────
// Firestore Security Rules — egitimtakvimi.oneteamglobal.ai
//
// Yetki modeli:
//   - PUBLIC: anonim kullanıcı (girişsiz takvim ziyaretçisi, başvuru yapan)
//   - ADMIN:  Firebase Auth + email whitelist (src/constants.js ADMIN_EMAILS)
//
// Whitelist email'leri burada da tutulmalı — server-side enforcement için
// kod tarafıyla SENKRON tutulmalıdır. Yeni admin eklerken iki yer:
//   1) src/constants.js -> ADMIN_EMAILS
//   2) bu dosya -> isAdmin() listesi
// ─────────────────────────────────────────────────────────────────────────

service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Yetki yardımcıları ───
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      // 2026-06-05 audit (#2): Custom Claims migrasyonu — transition mode
      // Yeni yöntem: request.auth.token.admin == true (claim)
      // Eski yöntem: email whitelist (migration tamamlanana kadar destek)
      // Migration tamam olunca eski liste kaldırılacak (bundle phishing target)
      return isSignedIn()
        && (
          request.auth.token.admin == true
          || request.auth.token.email in [
            's.emretopcu@gmail.com',
            'onlineakademin@gmail.com',
            'toygarsenelmis@gmail.com',
            'alper.kirbiyik@gmail.com',
            'vitamindestegi@gmail.com',
            'kmaziliguney@gmail.com',
            'ilknurakkas17@gmail.com',
            'giray70@gmail.com',
            'furkancite@gmail.com'
          ]
        );
    }

    // ─── KOLEKSİYONLAR ───

    // Eğitim takvimi — herkes görür, sadece admin yazar
    match /takvim/{docId} {
      allow read: if true;
      allow write: if isAdmin();

      // Katılımlar — "X kişi katıldı" sayacının dedup kaydı.
      // Yalnız /.netlify/functions/katil-tikla (admin SDK) yazar; client kapalı
      // (aynı 2026-06-05 puan-manipülasyon dersi: aggregate client'tan korunur).
      match /katilimlar/{uid} {
        allow read, write: if false;
      }
    }

    // Arşiv takvim — eski dönem kayıtları, sadece admin okur/yazar
    match /arsiv_takvim/{docId} {
      allow read, write: if isAdmin();
    }

    // Konuşmacılar — herkes görür; admin yazar VEYA lider kendi kaydını (email eşleşmeli) günceller.
    // Self-edit: giriş yapan e-posta doc'taki email ile aynıysa ve email alanı değiştirilmiyorsa.
    match /konusmacilar/{docId} {
      allow read: if true;
      allow write: if isAdmin();
      allow update: if isSignedIn()
        && resource != null
        && resource.data.email is string
        && request.auth.token.email == resource.data.email
        && request.resource.data.email == resource.data.email;
    }

    // Şablonlar — herkes görür (poster üretimi için), sadece admin yazar
    match /sablonlar/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Sistem ayarları — herkes okur (takvim yayın durumu için), sadece admin yazar
    match /settings/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Eğitmen başvuruları — anonim KAYIT yapabilir, sadece admin OKUR/günceller/siler
    // 2026-06-05 audit: Şema validasyonu — Firestore quota spam koruması
    match /egitmenler/{docId} {
      allow create: if
        request.resource.data.size() <= 30
        && request.resource.data.email is string
        && request.resource.data.email.size() > 0
        && request.resource.data.email.size() <= 200
        && (!('ad' in request.resource.data) || (request.resource.data.ad is string && request.resource.data.ad.size() <= 100))
        && (!('soyad' in request.resource.data) || (request.resource.data.soyad is string && request.resource.data.soyad.size() <= 100))
        && (!('telefon' in request.resource.data) || (request.resource.data.telefon is string && request.resource.data.telefon.size() <= 30))
        && (!('mesaj' in request.resource.data) || (request.resource.data.mesaj is string && request.resource.data.mesaj.size() <= 3000));
      allow read, update, delete: if isAdmin();
    }

    // Hatırlatma kayıtları — anonim KAYIT yapabilir, sadece admin OKUR
    // 2026-06-05 audit: Boyut + alan tipi validasyonu (quota saldırı koruma)
    match /hatirlatmalar/{docId} {
      allow create: if
        request.resource.data.size() <= 20
        && request.resource.data.egitimId is string
        && request.resource.data.egitimId.size() > 0
        && request.resource.data.egitimId.size() <= 100
        && request.resource.data.email is string
        && request.resource.data.email.size() > 0
        && request.resource.data.email.size() <= 200
        && request.resource.data.hatirlatmaZamani is string
        && request.resource.data.hatirlatmaZamani.size() <= 10
        && request.resource.data.gonderildi == false
        && (!('egitimAdi' in request.resource.data) || (request.resource.data.egitimAdi is string && request.resource.data.egitimAdi.size() <= 300))
        && (!('egitmen' in request.resource.data) || (request.resource.data.egitmen is string && request.resource.data.egitmen.size() <= 200))
        && (!('yer' in request.resource.data) || (request.resource.data.yer is string && request.resource.data.yer.size() <= 500))
        && (!('zoomLink' in request.resource.data) || (request.resource.data.zoomLink is string && request.resource.data.zoomLink.size() <= 500));
      allow read, list, update, delete: if isAdmin();
    }

    // Analytics event'leri — anonim YAZAR (pageview, lang_change vb), sadece admin OKUR
    // 2026-06-05 audit: Event payload boyut sınırı (spam koruma)
    match /egitim_analytics/{docId} {
      allow create: if
        request.resource.data.size() <= 15
        && request.resource.data.event is string
        && request.resource.data.event.size() <= 50
        && (!('path' in request.resource.data) || (request.resource.data.path is string && request.resource.data.path.size() <= 200))
        && (!('lang' in request.resource.data) || (request.resource.data.lang is string && request.resource.data.lang.size() <= 10))
        && (!('referrer' in request.resource.data) || (request.resource.data.referrer is string && request.resource.data.referrer.size() <= 500))
        && (!('userAgent' in request.resource.data) || (request.resource.data.userAgent is string && request.resource.data.userAgent.size() <= 500));
      allow read, list, update, delete: if isAdmin();
    }

    // Haftalık bülten aboneleri — anonim KAYIT olur, sadece admin OKUR
    // 2026-06-05 audit: email + ad boyut sınırı
    match /bulten_aboneleri/{docId} {
      allow create: if
        request.resource.data.size() <= 10
        && request.resource.data.email is string
        && request.resource.data.email.size() > 0
        && request.resource.data.email.size() <= 200
        && (!('ad' in request.resource.data) || (request.resource.data.ad is string && request.resource.data.ad.size() <= 100))
        && request.resource.data.aktif is bool;
      allow read, list, update, delete: if isAdmin();
    }

    // Konuşmacı takip aboneleri — anonim KAYIT olur, sadece admin OKUR
    // 2026-06-05 audit: email + konuşmacı coreId sınırı
    match /konusmaci_aboneleri/{docId} {
      allow create: if
        request.resource.data.size() <= 10
        && request.resource.data.email is string
        && request.resource.data.email.size() > 0
        && request.resource.data.email.size() <= 200
        && (!('konusmaciCoreId' in request.resource.data) || (request.resource.data.konusmaciCoreId is string && request.resource.data.konusmaciCoreId.size() <= 100));
      allow read, list, update, delete: if isAdmin();
    }

    // Web Push aboneleri — anonim KAYIT olur, sadece admin OKUR
    // 2026-06-05 audit: Push subscription endpoint/keys boyut sınırı
    match /web_push_aboneleri/{docId} {
      allow create: if
        request.resource.data.size() <= 15
        && (!('endpoint' in request.resource.data) || (request.resource.data.endpoint is string && request.resource.data.endpoint.size() <= 1000))
        && (!('keys' in request.resource.data) || request.resource.data.keys is map);
      allow read, list, update, delete: if isAdmin();
    }

    // Kayıtlı eğitimler (Vimeo videoları + transcript + AI kategori)
    // Herkes görür (kataloga read), sadece admin/Netlify Function yazar
    // Netlify Function firebase-admin SDK ile auth bypass eder
    //
    // Composite index'ler firestore.indexes.json içinde tanımlı.
    // Deploy: firebase deploy --only firestore
    match /kayitli_egitimler/{docId} {
      allow read: if true;
      allow write: if isAdmin();
      // 2026-06-05 audit fix (#3): puanOrt/puanSayisi artık client'tan YAZILAMAZ.
      // Eski rule: kullanıcı `puanOrt: 9999` yazabiliyordu (vote manipülasyon).
      // Yeni akış: client → /.netlify/functions/puan-oy-ver → admin SDK transaction
      // Sadece reactions hala client tarafından yazılabilir (low-risk emoji)
      allow update: if isSignedIn()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['reactions']);

      // Oylar subcollection — kullanıcı sadece kendi oyunu yazar/okur
      match /oylar/{uid} {
        allow read: if true;
        allow write: if isSignedIn() && request.auth.uid == uid;
      }

      // İzlenmeler subcollection — "en çok izlenen" sayacının dedup kaydı.
      // Yalnız /.netlify/functions/izlenme-kaydet (admin SDK) yazar; client asla
      // doğrudan yazamaz (yoksa parent izlenmeSayisi'nı client tetikleyip manipüle edebilir
      // — aynı 2026-06-05 puan-manipülasyon dersi). Okuma bile gerekmiyor, kapalı.
      match /izlenmeler/{uid} {
        allow read, write: if false;
      }

      // Reactions — emoji tepkileri (sadece kendi)
      match /reactions/{uid} {
        allow read: if true;
        allow write: if isSignedIn() && request.auth.uid == uid;
      }

      // Ekler — PDF/slide eki (admin yazar, herkes okur)
      match /ekler/{ekId} {
        allow read: if true;
        allow write: if isAdmin();
      }

      // Yorumlar subcollection — spam koruma + size limit + zaman validasyonu
      match /yorumlar/{yorumId} {
        allow read: if true;
        allow create: if isSignedIn()
          && request.resource.data.uid == request.auth.uid
          && request.resource.data.metin is string
          && request.resource.data.metin.size() > 0
          && request.resource.data.metin.size() <= 1000
          // tarih server-side gelmiş olmalı (clock skew önleme)
          && request.resource.data.tarih == request.time;
        allow update, delete: if isSignedIn() && resource.data.uid == request.auth.uid;
      }

      // Quiz cache — sadece server (Function) yazabilir, herkes okur
      match /quiz/{quizId} {
        allow read: if true;
        allow write: if false;
      }

      // AI analiz — ahaMoments + chapters + ozet (Function yazar, herkes okur)
      // collectionGroup query'ler için collectionGroup ayrıca açılır altta
      match /ai_analiz/{docId} {
        allow read: if true;
        allow write: if false;
      }
    }

    // collectionGroup query izni — bugunun-ilhami + bana-ozel-aha
    // backend'leri tüm ai_analiz alt-doc'larını tek query'de okuyor
    match /{path=**}/ai_analiz/{docId} {
      allow read: if true;
      allow write: if false;
    }

    // Silinen eğitimler kara listesi — vimeo-ingest tekrar eklemesin diye
    // Sadece admin yazabilir; admin SDK (CLI script) bypass eder
    // Public read kapalı (gizli liste, başkaları silinmiş içeriği görmesin)
    match /silinen_egitimler/{vimeoId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    // OneTeam Komisyonlar — public read, komisyon yetkili user'ları write
    // Yetki: ADMIN_EMAILS (genel admin) VEYA komisyon doc'undaki adminEmails listesinde olmak
    // adminEmails: KomisyonDetay save sırasında uyeler.email'lerinden + 3 global admin'den türetilir
    match /komisyonlar/{komisyonId} {
      allow read: if true;
      allow write: if isAdmin()
        || (isSignedIn()
            && resource != null
            && resource.data.adminEmails is list
            && request.auth.token.email in resource.data.adminEmails);
      // İlk oluşturma: sadece isAdmin (resource null olduğunda yukarıdaki kontrol bypass olur)
      allow create: if isAdmin();
    }

    // Site içerik (hakkimizda misyon/vizyon, yurutmekurulu üye listesi vb.)
    // Public read, sadece global admin yazar
    match /site_icerik/{key} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Giriş OTP kodları — sadece backend (Netlify function) yazar/okur
    // Frontend asla doğrudan okumamalı (kod sızıntısı)
    match /giris_otp/{docId} {
      allow read, write: if false; // backend admin SDK kullanır, rules atlanır
    }

    // Komisyon iletişim/öneri talepleri — anonim create (form), admin read
    // Spam koruması: maksimum mesaj boyutu + gerekli alanlar
    match /komisyon_iletisim_talepleri/{talepId} {
      allow read: if isAdmin();
      allow create: if
        request.resource.data.komisyonId is string
        && request.resource.data.komisyonId.size() > 0
        && request.resource.data.komisyonId.size() <= 50
        && request.resource.data.ad is string
        && request.resource.data.ad.size() > 0
        && request.resource.data.ad.size() <= 100
        && request.resource.data.email is string
        && request.resource.data.email.size() > 0
        && request.resource.data.email.size() <= 200
        && request.resource.data.mesaj is string
        && request.resource.data.mesaj.size() > 0
        && request.resource.data.mesaj.size() <= 2000
        && request.resource.data.olusturulmaTarihi == request.time;
      allow update, delete: if isAdmin();
    }

    // Üye profilleri — kendi profil doc'una okuma/yazma izni
    // Tier 1 üye girişi sonrası kullanıcı profili oluşturmak/güncellemek için.
    // Diğer kullanıcı profillerine erişim YOK (privacy).
    match /users/{uid} {
      allow read, write: if isSignedIn() && request.auth.uid == uid;

      // Eğitim durumu subcollection — kullanıcının kendi rank progress'i
      // İzleme durumu, hangi rank'lerin tamamlandığı, vs.
      // Admin ve Netlify scheduled function (admin SDK ile) erişebilir.
      match /egitim_durumu/{docId} {
        allow read, write: if isSignedIn() && request.auth.uid == uid;
        allow read: if isAdmin();  // Sponsor dashboard için (Faz 4)
      }

      // Davet log'u — sponsor'un kendi ekibine gönderdiği davetler
      // Sadece sahibi okur/yazar. Netlify Function admin SDK ile yazar.
      match /davetler/{amareId} {
        allow read: if isSignedIn() && request.auth.uid == uid;
        allow write: if false; // Sadece server (Function) yazabilir
      }

      // Karne log'u — haftalık lider karnesi snapshot'ları
      // ekibim Function her açılışta o haftanın snapshot'ını günceller
      match /karne_log/{weekKey} {
        allow read: if isSignedIn() && request.auth.uid == uid;
        allow write: if false; // Sadece server (Function) yazabilir
      }

      // AI asistan cache — Gemini önerisi 6 saatlik cache
      match /ai_cache/{docId} {
        allow read: if isSignedIn() && request.auth.uid == uid;
        allow write: if false; // Sadece server (Function) yazabilir
      }

      // Notlar — sponsor'un ekip üyelerine düştüğü notlar
      match /notlar/{amareId} {
        allow read, write: if isSignedIn() && request.auth.uid == uid;
      }

      // Onboarding checklist — sponsor'un her yeni üye için ilerleme takibi
      match /onboarding/{amareId} {
        allow read, write: if isSignedIn() && request.auth.uid == uid;
      }

      // Notification subscriptions — sponsor'un push abone olduğu olaylar
      match /push_aboneleri/{docId} {
        allow read, write: if isSignedIn() && request.auth.uid == uid;
      }

      // Video bookmark'lar — kullanıcının zaman damgalı işaretleri
      match /bookmarks/{docId} {
        allow read, write: if isSignedIn() && request.auth.uid == uid;
      }

      // Meta — watch_progress sync, cihazlar arası senkron
      match /meta/{docId} {
        allow read, write: if isSignedIn() && request.auth.uid == uid;
      }

      // Quiz sonuçları — kullanıcının quiz skorları
      match /quiz_sonuclari/{vimeoId} {
        allow read, write: if isSignedIn() && request.auth.uid == uid;
      }
    }

    // Eğitim yolları — admin tarafından her rank için küratör edilmiş video listesi
    // Herkes okur (kullanıcı kendi rank'inin curriculum'unu görür)
    // Sadece admin yazar (kayitli_egitimler'den video seçer)
    match /egitim_yollari/{rankKey} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // AI rank önerileri — her rank için Gemini puanladığı top videolar
    // Admin görür (henüz onaylanmamış öneriler), admin onaylayıp egitim_yollari'a kopyalar
    match /rank_oneriler/{rankKey} {
      allow read: if isAdmin();
      allow write: if false; // Sadece backend (Function) yazar
    }

    // Leaderboard cache — global, 1 saatlik
    // Server tarafından yazılır, signed-in kullanıcılar okur
    match /leaderboard_cache/{week} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    // Public liderler cache — herkes okur (anonim ziyaretçi dahil)
    // İçerik maskeli isimlerle kaydedilir
    match /liderler_cache/{week} {
      allow read: if true;
      allow write: if false;
    }

    // Audit log — sadece admin okur, signed-in yazar (kendi action'ını)
    // 2026-06-05 audit: action/target/ts validasyonu eklendi (sahte log entry koruma)
    match /audit_log/{logId} {
      allow read: if isAdmin();
      allow create: if isSignedIn()
        && request.resource.data.kim == request.auth.uid
        && request.resource.data.size() <= 15
        && request.resource.data.action is string
        && request.resource.data.action.size() > 0
        && request.resource.data.action.size() <= 64
        && (!('target' in request.resource.data) || (request.resource.data.target is string && request.resource.data.target.size() <= 200))
        && (!('meta' in request.resource.data) || (request.resource.data.meta is map))
        && (!('ts' in request.resource.data) || (request.resource.data.ts == request.time));
      allow update, delete: if false;
    }

    // Kısa davet linkleri — sadece server (kisalt function) okur/yazar
    // Public kullanıcı redirect üzerinden, doğrudan Firestore'a değil
    match /kisaltmalar/{kod} {
      allow read, write: if false;
    }

    // Rate limit kayıtları — sadece server (Functions) okur/yazar
    // IP hash'leri burada saklı, kimse direkt erişemez
    match /rate_limits/{docId} {
      allow read, write: if false;
    }

    // Magic link gönderim log'u — idempotency için (60sn cooldown)
    // Sadece server yazar, kimse okumaz (PII korumalı)
    match /giris_link_log/{amareId} {
      allow read, write: if false;
    }

    // Email düzeltme talepleri — kullanıcı talep yazar (server)
    // Admin okur ve onaylar/reddeder
    match /email_duzeltme_talepleri/{talepId} {
      allow read: if isAdmin();
      allow write: if false; // Sadece backend (email-duzelt-talep) yazar
    }

    // Popüler anlar — topluluk tıklama sayacı
    // Sadece server (anlar-popularla Function) yazar
    // Public okuma — widget herkese görünür
    match /popular_anlar/{docId} {
      allow read: if true;
      allow write: if false;
    }
    match /popular_anlar_cache/{docId} {
      allow read: if true;
      allow write: if false;
    }

    // Eğitmen quotes cache — public okuma, sadece server yazar
    match /egitmen_quotes_cache/{coreId} {
      allow read: if true;
      allow write: if false;
    }

    // Günlük ilham cache — public okuma, sadece server yazar
    match /gunluk_ilham_cache/{day} {
      allow read: if true;
      allow write: if false;
    }

    // Kolektif istatistik (2026 epic hedef) — public okuma, sadece server (scheduled) yazar
    // McGonigal FIX #6: topluluk hedefi herkese görünür
    match /global_stats/{yil} {
      allow read: if true;
      allow write: if false;
    }

    // Diğer her koleksiyon — varsayılan: tamamen kapalı
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
