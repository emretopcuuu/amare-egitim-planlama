# Bu dosyayı .env olarak kopyala, gerçek değerleri gir.
# .env dosyası .gitignore'a eklenmiş olmalı.

# Firebase Admin SDK — Firebase Console → Project Settings → Service Accounts
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Vimeo API (CREDENTIALS_BACKUP.md'den)
VIMEO_TOKEN=

# Gemini API (kategorize için)
GEMINI_API_KEY=

# Transcript JSON path (default: Desktop\OneTeamAI-Automation\deploy\netlify\functions\turkish-transcripts.json)
# TRANSCRIPTS_PATH=
