# Supabase (sunucu tarafı — asla NEXT_PUBLIC yapma)
SUPABASE_URL=https://swxfxeuxlriuoecjxdla.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# Supabase (istemci tarafı — Faz 5 canlı ekran için; deny-all RLS sayesinde tablo okuyamaz)
NEXT_PUBLIC_SUPABASE_URL=https://swxfxeuxlriuoecjxdla.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Oturum imzalama anahtarı: en az 32 bayt rastgele değer
# Üretmek için: openssl rand -base64 32
SESSION_SECRET=

# Yönetici paneli şifresi
ADMIN_PASSWORD=

# AI Ayna Mektubu (Faz 4) — Claude API anahtarı (platform.claude.com)
# Tanımlı değilse uygulama çalışır; yalnızca mektup üretimi devre dışı kalır.
ANTHROPIC_API_KEY=

# 90 gün sonrası davet e-postaları (Faz 6) — Postmark
# Tanımlı değilse uygulama çalışır; yalnızca davet gönderimi devre dışı kalır.
POSTMARK_SERVER_TOKEN=
EMAIL_FROM=

# AYNA — yapay zekâ kamp direktörü (Faz 7)
# VAPID: PWA push anahtar çifti → npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
# Tik ucu gizli anahtarı (Supabase cron aynı değerle çağırır) → openssl rand -hex 24
AYNA_TIK_SECRET=
ELEVENLABS_API_KEY=
HIGGSFIELD_CREDENTIALS=
# AYNA marka sesi (ElevenLabs ses kimliği; boşsa derin/nötr hazır ses kullanılır)
AYNA_SES_ID=
# Direnç Simülatörü itirazcısının sesi (boşsa hazır karakter sesi)
ITIRAZCI_SES_ID=
