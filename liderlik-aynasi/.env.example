# Supabase (sunucu tarafı — asla NEXT_PUBLIC yapma). Tüm DB erişimi service-role
# ile sunucudan; istemci anon client KULLANMAZ (deny-all RLS + derinlemesine savunma).
SUPABASE_URL=https://swxfxeuxlriuoecjxdla.supabase.co
SUPABASE_SERVICE_ROLE_KEY=
# Bazı dağıtımlarda yeni adlandırma; varsa kopyala.
SUPABASE_SECRET_KEY=

# Oturum imzalama anahtarı: en az 32 bayt rastgele değer
# Üretmek için: openssl rand -base64 32
SESSION_SECRET=

# Yönetici paneli şifresi (tam yetki)
ADMIN_PASSWORD=

# Yardımcı görevli şifresi (sınırlı: yalnız izleme + hatırlatma). İsteğe bağlı;
# tanımlı değilse yardımcı girişi devre dışı kalır.
YARDIMCI_PASSWORD=

# AI Ayna Mektubu (Faz 4) — Claude API anahtarı (platform.claude.com)
# Tanımlı değilse uygulama çalışır; yalnızca mektup üretimi devre dışı kalır.
ANTHROPIC_API_KEY=

# 90 gün sonrası davet e-postaları (Faz 6) — Postmark
# Tanımlı değilse uygulama çalışır; yalnızca davet gönderimi devre dışı kalır.
POSTMARK_SERVER_TOKEN=
EMAIL_FROM=

# AYNA — yapay zekâ kamp direktörü (Faz 7)
# VAPID: PWA push anahtar çifti → npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
# Tik ucu gizli anahtarı (Supabase cron aynı değerle çağırır) → openssl rand -hex 24
AYNA_TIK_SECRET=
ELEVENLABS_API_KEY=
HIGGSFIELD_CREDENTIALS=
# Higgsfield karakter (çok-görsel) modeli — tanımlıysa zengin üretim, yoksa tek görsele düşer
HIGGSFIELD_KARAKTER_MODEL=
# AYNA marka sesi (ElevenLabs ses kimliği; boşsa derin/nötr hazır ses kullanılır)
AYNA_SES_ID=
# Direnç Simülatörü itirazcısının sesi (boşsa hazır karakter sesi)
ITIRAZCI_SES_ID=

# Zamanlanmış olay cron'u (/api/cron/olaylar) Bearer koruması. Tanımlıysa cron
# çağrısı "Authorization: Bearer <değer>" göndermeli (Railway/Cloudflare cron için).
# Tanımlı değilse uç açık çalışır (Vercel cron'u böyle çağırır). → openssl rand -hex 24
CRON_SECRET=

# Diğer (varsa Vercel'den kopyala; opsiyonel/özellik bayrakları)
ICEBERG_TOKEN=
BOOK_LANG=
